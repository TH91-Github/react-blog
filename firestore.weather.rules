rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /weather/{region}/districtCode/{districtCode} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;

      match /year/{year} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
